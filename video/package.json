{
  "name": "@swarm-apps/swarmdrop-hero-video",
  "version": "1.0.0",
  "description": "SwarmDrop 官网 Hero 视频工程",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.489",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.489"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.489",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "studio": "remotion studio",
    "build": "remotion bundle",
    "render:hero": "mkdir -p ../docs/public/hero && remotion render src/index.ts HeroLoop ../docs/public/hero/swarmdrop-hero.mp4 --codec=h264 --video-bitrate=2M",
    "render:poster": "mkdir -p ../docs/public/hero && remotion still src/index.ts HeroLoop ../docs/public/hero/swarmdrop-hero-poster.png --frame=555",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
