# UpgradeLink 凭证 —— Android in-app update（src/core/upgrade-client.ts）。
# 全部三个值都填后，启动 2s 自动检查 + AppState 回前台时检查；任一为空时
# isUpgradeLinkConfigured() 会返回 false，整套升级流程降级为 no-op。
#
# 与桌面 SwarmDrop 用同一套 UpgradeLink 服务，apkKey 单独申请（移动端独立）。
# 这些值会被打进 JS bundle，跟桌面端取舍一致：accessKey 仅授权匿名查询/上报。
EXPO_PUBLIC_UPGRADELINK_ACCESS_KEY=
EXPO_PUBLIC_UPGRADELINK_ACCESS_SECRET=
EXPO_PUBLIC_UPGRADELINK_APK_KEY=
