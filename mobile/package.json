    "expo-file-system": "^55.0.16",
    "expo-notifications": "~0.32.13",
    "expo-router": "~55.0.11",
    "expo-secure-store": "^55.0.13",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.14",
    "lucide-react-native": "^1.8.0",
