{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "swarmdrop",
  "version": "0.5.0",
  "identifier": "com.yexiyue.swarmdrop",
  "build": {
    "beforeDevCommand": "pnpm dev --host",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SwarmDrop",
        "width": 1000,
        "height": 720,
        "minWidth": 360,
        "minHeight": 480,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 12, "y": 22 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDOUYzRTBFNjBEMjBDNEEKUldSS0ROSmdEajZmSEhVa2N5cUFWRXRoMzQ2eUQwK0IvTVFrdXNkSmpoaEVJYUNzUEpkM2xaejAK",
      "endpoints": [
        "http://47.115.172.218:3030/api/v1/updates/tauri/swarmdrop?current_version={{current_version}}&target={{target}}&arch={{arch}}"
      ],
      "dangerousInsecureTransportProtocol": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
