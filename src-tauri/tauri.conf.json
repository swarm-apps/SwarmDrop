{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "swarmdrop",
  "version": "0.7.5",
  "identifier": "com.yexiyue.swarmdrop",
  "build": {
    "beforeDevCommand": "pnpm dev --host",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SwarmDrop",
        "width": 960,
        "height": 720,
        "minWidth": 360,
        "minHeight": 480,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 12, "y": 22 }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$DOWNLOAD/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "name": "Sendable File",
        "description": "Send with SwarmDrop",
        "role": "Viewer",
        "rank": "Alternate",
        "ext": [
          "pdf", "doc", "docx", "xls", "xlsx", "ppt", "pptx", "odt", "ods", "odp",
          "rtf", "epub", "csv", "tsv", "pages", "numbers", "key",
          "txt", "md", "markdown", "rst", "log", "json", "jsonl", "xml", "yaml",
          "yml", "toml", "ini", "cfg", "conf", "env", "sql", "html", "htm", "css",
          "scss", "less", "js", "mjs", "cjs", "ts", "tsx", "jsx", "vue", "svelte",
          "py", "rs", "go", "java", "kt", "swift", "c", "cc", "cpp", "h", "hpp",
          "cs", "rb", "php", "sh", "bash", "zsh", "lua", "r", "dart",
          "png", "jpg", "jpeg", "gif", "webp", "heic", "heif", "bmp", "tiff", "tif",
          "svg", "ico", "avif", "psd", "raw",
          "mp4", "mov", "m4v", "webm", "mkv", "avi", "wmv", "flv", "3gp", "mpg", "mpeg",
          "mp3", "wav", "flac", "aac", "m4a", "ogg", "opus", "aiff", "wma",
          "zip", "rar", "7z", "tar", "gz", "tgz", "bz2", "xz", "zst",
          "sketch", "fig", "ai", "eps", "blend", "obj", "stl", "gltf", "glb",
          "db", "sqlite", "parquet", "bin", "dat"
        ]
      }
    ],
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDOUYzRTBFNjBEMjBDNEEKUldSS0ROSmdEajZmSEhVa2N5cUFWRXRoMzQ2eUQwK0IvTVFrdXNkSmpoaEVJYUNzUEpkM2xaejAK",
      "endpoints": [
        "http://47.115.172.218:3030/api/v1/updates/tauri/swarmdrop?current_version={{current_version}}&target={{target}}&arch={{arch}}"
      ],
      "dangerousInsecureTransportProtocol": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
