<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS「用 SwarmDrop 打开」文件关联。Tauri v2 会按文件名约定把本 Info.plist
  merge 进打包后的 Info.plist。

  用 LSItemContentTypes=public.data + public.folder 声明「任意文件 + 文件夹」——
  Tauri 的 bundle.fileAssociations 只能按扩展名（ext）注册，表达不了通配，故走自定义 plist。

  CFBundleTypeRole=Viewer + LSHandlerRank=Alternate = 出现在「打开方式」列表里，
  但绝不抢占任何类型的默认打开程序。（注意：Role=None 会让 app 不作为 opener 出现，
  与目标相反，所以这里用 Viewer。）
-->
<plist version="1.0">
  <dict>
    <key>CFBundleDocumentTypes</key>
    <array>
      <dict>
        <key>CFBundleTypeName</key>
        <string>Any File or Folder</string>
        <key>CFBundleTypeRole</key>
        <string>Viewer</string>
        <key>LSHandlerRank</key>
        <string>Alternate</string>
        <key>LSItemContentTypes</key>
        <array>
          <string>public.data</string>
          <string>public.folder</string>
        </array>
      </dict>
    </array>
  </dict>
</plist>
